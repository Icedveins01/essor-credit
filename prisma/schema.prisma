generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id         String    @id @default(cuid())
  nom        String
  prenom     String
  email      String    @unique
  telephone  String?
  motDePasse String
  sexe       String?
  adresse    String?
  ville      String?
  pays       String?
  createdAt  DateTime  @default(now())

  demandes   Demande[]
}

model Demande {
  id                  String   @id @default(cuid())
  clientId            String
  typePret            String
  montant             Float
  duree               Int
  mensualite          Float
  coutTotal           Float
  interets            Float
  statut              String   @default("Demande reçue")
  createdAt           DateTime @default(now())
  activationCode      String?
  transferStopPercent Int?

  client    Client          @relation(fields: [clientId], references: [id])
  documents Document[]
  timeline  TimelineEvent[]
}

model Document {
  id         String   @id @default(cuid())
  demandeId  String
  nom        String
  url        String
  type       String
  uploadedAt DateTime @default(now())

  demande Demande @relation(fields: [demandeId], references: [id])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  demandeId   String
  titre       String
  description String?
  date        DateTime @default(now())

  demande Demande @relation(fields: [demandeId], references: [id])
}

model Admin {
  id         String   @id @default(cuid())
  email      String   @unique
  motDePasse String
  role       String   @default("admin")
  createdAt  DateTime @default(now())
}